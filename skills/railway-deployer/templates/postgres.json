{
  "name": "PostgreSQL Database",
  "description": "PostgreSQL database with persistent storage",
  "services": [
    {
      "name": "postgres",
      "source": {
        "type": "docker",
        "image": "postgres:16"
      },
      "volumes": [
        {
          "mountPath": "/var/lib/postgresql/data"
        }
      ]
    }
  ]
}
