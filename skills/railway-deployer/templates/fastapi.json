{
  "name": "FastAPI + PostgreSQL",
  "description": "FastAPI backend with PostgreSQL database",
  "services": [
    {
      "name": "api",
      "source": {
        "type": "github",
        "repo": "railwayapp-templates/fastapi",
        "branch": "main"
      },
      "variables": {
        "DATABASE_URL": "${{SERVICE.postgres.DATABASE_URL}}",
        "SECRET_KEY": "${{secret(32)}}"
      },
      "settings": {
        "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT",
        "healthcheckPath": "/health"
      },
      "networking": {
        "public": true
      }
    },
    {
      "name": "postgres",
      "source": {
        "type": "docker",
        "image": "postgres:16"
      },
      "volumes": [
        {
          "mountPath": "/var/lib/postgresql/data"
        }
      ]
    }
  ]
}
