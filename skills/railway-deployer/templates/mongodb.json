{
  "name": "MongoDB Database",
  "description": "MongoDB database with persistent storage",
  "services": [
    {
      "name": "mongodb",
      "source": {
        "type": "docker",
        "image": "mongo:7"
      },
      "volumes": [
        {
          "mountPath": "/data/db"
        }
      ]
    }
  ]
}
