# ============================================================
# Open Manus — Environment Variables for Railway Deployment
# Copy this to .env and fill in your API keys.
# On Railway, set these as environment variables in the dashboard.
# ============================================================

# =============================================================================
# REQUIRED: LLM Provider
# =============================================================================
# OpenRouter gives access to 200+ models through a single API key.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default model. Recommended options:
#   anthropic/claude-opus-4.6     — Best reasoning, highest capability (expensive)
#   anthropic/claude-sonnet-4-5   — Excellent balance of speed and capability
#   google/gemini-2.5-flash       — Fast, cheap, very capable
#   openai/gpt-4.1                — Strong all-rounder
LLM_MODEL=anthropic/claude-opus-4.6

# =============================================================================
# RECOMMENDED: Tool API Keys
# =============================================================================

# Firecrawl — Web search, crawl, and extract (powers the web_search tool)
# Get at: https://firecrawl.dev/
FIRECRAWL_API_KEY=

# Browserbase — Cloud browser automation (powers the browser tool)
# Get at: https://browserbase.com/
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# FAL.ai — Image generation (powers the image_generation tool)
# Get at: https://fal.ai/
FAL_KEY=

# ElevenLabs — Text-to-speech and speech-to-text (powers the tts and transcription tools)
# Get at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# =============================================================================
# OPTIONAL: Additional Integrations
# =============================================================================

# GitHub — For Skills Hub search/install and GitHub tool integration
# Get at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Honcho — Cross-session user modeling (optional but enhances memory)
# Get at: https://app.honcho.dev
HONCHO_API_KEY=

# =============================================================================
# OPEN MANUS SPECIFIC SETTINGS
# =============================================================================

# Workspace directory (where files are saved)
HERMES_WORKSPACE_DIR=/root/.hermes/workspace

# Terminal backend (local = runs inside the Docker container)
TERMINAL_ENV=local
TERMINAL_TIMEOUT=180
TERMINAL_LIFETIME_SECONDS=600

# Map-Reduce settings
MAP_REDUCE_MAX_WORKERS=5
MAP_REDUCE_MODEL=google/gemini-2.0-flash-001

# Context compression model (use a cheap/fast model)
CONTEXT_COMPRESSION_ENABLED=true

# Gateway settings
PORT=8080
GATEWAY_ALLOW_ALL_USERS=true

# =============================================================================
# DEBUG (set to true to enable verbose logging)
# =============================================================================
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false
